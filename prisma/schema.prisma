generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model appointments {
  appointment_id                        Int          @id @default(autoincrement())
  hospital_id                           Int
  patient_id                            Int
  doctor_id                             Int
  appointment_no                        String       @unique(map: "uq_appointment_no") @db.VarChar(50)
  appointment_date                      DateTime     @db.Date
  appointment_time                      DateTime     @db.Time(6)
  appointment_status                    String       @db.VarChar(30)
  remarks                               String?      @db.VarChar(250)
  is_active                             Boolean?     @default(true)
  created_by                            Int
  modified_by                           Int
  created_at                            DateTime     @default(now()) @db.Timestamptz(6)
  modified_at                           DateTime     @default(now()) @db.Timestamptz(6)
  users_appointments_created_byTousers  users        @relation("appointments_created_byTousers", fields: [created_by], references: [user_id], onDelete: NoAction, onUpdate: NoAction)
  doctors                               doctors      @relation(fields: [doctor_id], references: [doctor_id], onDelete: NoAction, onUpdate: NoAction)
  hospitals                             hospitals    @relation(fields: [hospital_id], references: [hospital_id], onDelete: NoAction, onUpdate: NoAction)
  users_appointments_modified_byTousers users        @relation("appointments_modified_byTousers", fields: [modified_by], references: [user_id], onDelete: NoAction, onUpdate: NoAction)
  patients                              patients     @relation(fields: [patient_id], references: [patient_id], onDelete: NoAction, onUpdate: NoAction)
  opd_visits                            opd_visits[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model bill_items {
  bill_item_id     Int      @id @default(autoincrement())
  bill_id          Int
  item_type        String   @db.VarChar(50)
  reference_id     Int?
  item_description String   @db.VarChar(250)
  quantity         Int      @default(1)
  unit_price       Decimal  @db.Decimal(10, 2)
  total_price      Decimal  @db.Decimal(10, 2)
  created_at       DateTime @default(now()) @db.Timestamptz(6)
  billing          billing  @relation(fields: [bill_id], references: [bill_id], onDelete: NoAction, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model billing {
  bill_id                          Int          @id @default(autoincrement())
  hospital_id                      Int
  visit_id                         Int
  bill_number                      String       @unique @db.VarChar(50)
  bill_date                        DateTime     @default(dbgenerated("CURRENT_DATE")) @db.Date
  subtotal_amount                  Decimal      @db.Decimal(10, 2)
  tax_amount                       Decimal      @default(0) @db.Decimal(10, 2)
  discount_amount                  Decimal      @default(0) @db.Decimal(10, 2)
  total_amount                     Decimal?     @default(dbgenerated("((subtotal_amount + tax_amount) - discount_amount)")) @db.Decimal(10, 2)
  payment_status                   String       @db.VarChar(50)
  billing_status                   String       @db.VarChar(50)
  is_active                        Boolean?     @default(true)
  created_by                       Int
  modified_by                      Int
  created_at                       DateTime     @default(now()) @db.Timestamptz(6)
  modified_at                      DateTime     @default(now()) @db.Timestamptz(6)
  bill_items                       bill_items[]
  users_billing_created_byTousers  users        @relation("billing_created_byTousers", fields: [created_by], references: [user_id], onDelete: NoAction, onUpdate: NoAction)
  hospitals                        hospitals    @relation(fields: [hospital_id], references: [hospital_id], onDelete: NoAction, onUpdate: NoAction)
  users_billing_modified_byTousers users        @relation("billing_modified_byTousers", fields: [modified_by], references: [user_id], onDelete: NoAction, onUpdate: NoAction)
  opd_visits                       opd_visits   @relation(fields: [visit_id], references: [opd_id], onDelete: NoAction, onUpdate: NoAction)
  payments                         payments[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model blood_groups {
  blood_group_id   Int        @id @default(autoincrement())
  blood_group_name String     @unique(map: "uq_blood_group") @db.VarChar(10)
  is_active        Boolean    @default(true)
  created_at       DateTime   @default(now()) @db.Timestamptz(6)
  modified_at      DateTime   @default(now()) @db.Timestamptz(6)
  patients         patients[]
}

model cities {
  city_id     Int         @id @default(autoincrement())
  state_id    Int
  city_name   String      @db.VarChar(150)
  city_code   String      @db.VarChar(20)
  is_active   Boolean     @default(true)
  created_at  DateTime    @default(now()) @db.Timestamptz(6)
  modified_at DateTime    @default(now()) @db.Timestamptz(6)
  states      states      @relation(fields: [state_id], references: [state_id], onDelete: NoAction, onUpdate: NoAction)
  hospitals   hospitals[]
  patients    patients[]

  @@unique([state_id, city_name], map: "uq_city_state")
}

model group_counters {
  counter_id        Int             @id @default(autoincrement())
  hospital_group_id Int
  counter_type      String          @db.VarChar(50)
  prefix            String?         @db.VarChar(20)
  current_value     Int             @default(0)
  is_active         Boolean?        @default(true)
  created_at        DateTime?       @default(now()) @db.Timestamptz(6)
  modified_at       DateTime?       @default(now()) @db.Timestamptz(6)
  hospital_groups   hospital_groups @relation(fields: [hospital_group_id], references: [hospital_group_id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([hospital_group_id, counter_type], map: "uq_group_counter")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model daily_queues {
  daily_queue_id                        Int            @id @default(autoincrement())
  hospital_id                           Int
  doctor_id                             Int
  queue_date                            DateTime       @db.Date
  current_token                         Int            @default(0)
  status                                String         @db.VarChar(20)
  opened_at                             DateTime       @default(now()) @db.Timestamptz(6)
  closed_at                             DateTime?      @db.Timestamptz(6)
  created_by                            Int
  modified_by                           Int
  created_at                            DateTime       @default(now()) @db.Timestamptz(6)
  modified_at                           DateTime       @default(now()) @db.Timestamptz(6)
  users_daily_queues_created_byTousers  users          @relation("daily_queues_created_byTousers", fields: [created_by], references: [user_id], onDelete: NoAction, onUpdate: NoAction)
  doctors                               doctors        @relation(fields: [doctor_id], references: [doctor_id], onDelete: NoAction, onUpdate: NoAction)
  hospitals                             hospitals      @relation(fields: [hospital_id], references: [hospital_id], onDelete: NoAction, onUpdate: NoAction)
  users_daily_queues_modified_byTousers users          @relation("daily_queues_modified_byTousers", fields: [modified_by], references: [user_id], onDelete: NoAction, onUpdate: NoAction)
  queue_tokens                          queue_tokens[]

  @@unique([hospital_id, doctor_id, queue_date], map: "uq_daily_queue")
}

model departments_master {
  department_id        Int                    @id @default(autoincrement())
  department_code      String                 @unique(map: "uq_department_code") @db.VarChar(50)
  department_name      String                 @db.VarChar(150)
  description          String?                @db.VarChar(250)
  created_at           DateTime               @default(now()) @db.Timestamptz(6)
  diagnoses            diagnoses[]
  doctors              doctors[]
  hospital_departments hospital_departments[]
  tests                tests[]
  treatment_types      treatment_types[]
}

model diagnoses {
  diagnosis_id       Int                  @id @default(autoincrement())
  diagnosis_code     String               @unique @db.VarChar(50)
  diagnosis_name     String               @db.VarChar(200)
  description        String?              @db.VarChar(500)
  department_id      Int
  departments_master departments_master   @relation(fields: [department_id], references: [department_id], onDelete: NoAction, onUpdate: NoAction)
  hospital_diagnoses hospital_diagnoses[]
  opd_diagnoses      opd_diagnoses[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model doctor_availability {
  availability_id  Int      @id @default(autoincrement())
  doctor_id        Int
  day_of_week      Int
  start_time       DateTime @db.Time(6)
  end_time         DateTime @db.Time(6)
  max_appointments Int
  is_available     Boolean? @default(true)
  created_at       DateTime @default(now()) @db.Timestamptz(6)
  modified_at      DateTime @default(now()) @db.Timestamptz(6)
  doctors          doctors  @relation(fields: [doctor_id], references: [doctor_id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([doctor_id, day_of_week], map: "uq_doctor_day")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
